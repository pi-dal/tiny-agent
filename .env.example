# Set your OpenAI-compatible API key
OPENAI_API_KEY=sk-...

# Optional: override default model (default: gpt-4o-mini)
# AGENT_MODEL=gpt-4o

# Optional: custom OpenAI-compatible base URL
# Works with Ollama, LM Studio, vLLM, OpenRouter, etc.
# AGENT_BASE_URL=http://localhost:11434/v1

# Optional: custom session storage location (default: ~/.agent/sessions)
# AGENT_SESSIONS_DIR=/path/to/sessions